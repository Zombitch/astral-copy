/* About */
"about.button" = "Info";
"about.studio" = "2026 © Lux Anima Studio";
"about.intro" = "AstralCopy ist eine macOS-App, die sich still in Ihrer Menüleiste einrichtet – für alles, was Sie kopieren, immer nur einen Shortcut entfernt. Wir haben diese App entwickelt, um uns beim Erstellen und Entwickeln von Spielen zu unterstützen. Wir stellen sie kostenlos zur Verfügung, um anderen wie uns zu helfen, die ein einfaches Multi-Copy/Paste-Tool suchen.";
"about.feature.history" = "Merkt sich alles, was Sie kopieren – Texte und Bilder – bis zu den letzten 50 Einträgen, damit nichts verloren geht.";
"about.feature.shortcut" = "Drücken Sie ⌘⇧V in jeder App, um Ihren Verlauf zu öffnen. Wählen Sie einen Eintrag aus, um ihn zu kopieren, und fügen Sie ihn dann normal mit Cmd+V ein.";
"about.feature.cmdv" = "Ihr gewohntes Cmd+V funktioniert weiterhin genau wie zuvor — Ihr Arbeitsablauf bleibt unverändert.";

