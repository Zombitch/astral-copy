/* About */
"about.button" = "Acerca de";
"about.studio" = "2026 © Lux Anima Studio";
"about.intro" = "AstralCopy es una app de macOS que vive discretamente en su barra de menús para todo lo que copia, siempre a un atajo de distancia. Desarrollamos esta app para ayudarnos mientras creamos y desarrollamos videojuegos. La distribuimos de forma gratuita para ayudar a otras personas como nosotros que buscan una herramienta simple de copiar/pegar múltiple.";
"about.feature.history" = "Recuerda todo lo que copia — texto e imágenes — hasta los últimos 50 elementos, para que nada se pierda.";
"about.feature.shortcut" = "Pulse Ctrl+V en lugar del habitual Cmd+V para abrir un panel con su historial de copias. Haga clic en cualquier elemento para pegarlo en la app que esté usando.";
"about.feature.cmdv" = "Cmd+V sigue funcionando exactamente igual — nada de su flujo de trabajo habitual se ve afectado.";

